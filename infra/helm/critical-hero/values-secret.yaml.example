# Copy to values-secret.yaml (gitignored) and fill in real values.
# Deploy with: helm upgrade --install critical-hero infra/helm/critical-hero -f values-secret.yaml
global:
  clickhouse:
    host: https://your-instance.ap-northeast-2.aws.clickhouse.cloud
    password: CHANGE_ME
  postgres:
    password: CHANGE_ME
  anthropicApiKey: CHANGE_ME
  openaiApiKey: CHANGE_ME
  githubToken: CHANGE_ME
  githubWebhookSecret: CHANGE_ME
  notionToken: CHANGE_ME
  notionDatabaseId: CHANGE_ME
  slackBotToken: CHANGE_ME
  slackSigningSecret: CHANGE_ME
  slackAppToken: CHANGE_ME

mcp-server:
  image:
    repository: 897744604563.dkr.ecr.ap-northeast-2.amazonaws.com/eeeemune/critical-hero
    tag: mcp-server
  service:
    certificateArn: arn:aws:acm:ap-northeast-2:897744604563:certificate/CHANGE_ME

slack:
  image:
    repository: 897744604563.dkr.ecr.ap-northeast-2.amazonaws.com/eeeemune/critical-hero
    tag: slack
