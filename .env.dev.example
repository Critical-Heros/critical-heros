# Dev config — points at the local docker-compose stack (`docker compose up -d`).
# Copy to .env for local development: cp .env.dev.example .env
NODE_ENV=local
TARGET_ENVIRONMENT=develop

# Postgres (docker-compose)
DATABASE_URL=postgres://postgres:password@localhost:5432/critical_hero

# ClickHouse (docker-compose) — client is scheme-aware; http for local
CLICKHOUSE_HOST=http://localhost
CLICKHOUSE_PORT=8123
CLICKHOUSE_DB=critical_hero
CLICKHOUSE_USER=default
CLICKHOUSE_PASSWORD=clickhouse

# Ports
PORT=8401
SLACK_PORT=3002

# AI provider
AGENT_PROVIDER=claude
ANTHROPIC_API_KEY=sk-ant-xxx
CLAUDE_MODEL=claude-sonnet-4-6
OPENAI_API_KEY=sk-xxx
OPENAI_MODEL=text-embedding-3-small

# GitHub
GITHUB_TOKEN=ghp_xxx
GITHUB_WEBHOOK_SECRET=changeme

# Slack (HTTP mode locally)
SLACK_BOT_TOKEN=xoxb-xxx
SLACK_SIGNING_SECRET=xxx
SLACK_APP_TOKEN=xapp-xxx
SLACK_SOCKET_MODE=false
SLACK_CRITICAL_CHANNEL=#critical
SLACK_INCIDENT_CHANNELS=#incidents

# Notion
NOTION_TOKEN=secret_xxx
NOTION_DATABASE_ID=xxx

# Optional
DEFAULT_REPO_ID=
