# Prod config — these keys are injected via the Helm Secret
# (infra/helm/cmcp/values-secret.yaml). This file documents the full key set.
# Never commit real secret values.
NODE_ENV=production
TARGET_ENVIRONMENT=production

# Postgres — in-cluster service (Helm db subchart)
DATABASE_URL=postgres://postgres:CHANGE_ME@cmcp-postgres:5432/critical_hero

# ClickHouse Cloud (external) — full https host + 8443
CLICKHOUSE_HOST=https://your-instance.ap-northeast-2.aws.clickhouse.cloud
CLICKHOUSE_PORT=8443
CLICKHOUSE_DB=critical_hero
CLICKHOUSE_USER=default
CLICKHOUSE_PASSWORD=CHANGE_ME

# Ports
PORT=8401
SLACK_PORT=3002

# AI provider
AGENT_PROVIDER=claude
ANTHROPIC_API_KEY=CHANGE_ME
CLAUDE_MODEL=claude-sonnet-4-6
OPENAI_API_KEY=CHANGE_ME
OPENAI_MODEL=text-embedding-3-small

# GitHub
GITHUB_TOKEN=CHANGE_ME
GITHUB_WEBHOOK_SECRET=CHANGE_ME

# Slack (Socket Mode in prod — no inbound port needed)
SLACK_BOT_TOKEN=CHANGE_ME
SLACK_SIGNING_SECRET=CHANGE_ME
SLACK_APP_TOKEN=CHANGE_ME
SLACK_SOCKET_MODE=true
SLACK_CRITICAL_CHANNEL=#critical
SLACK_INCIDENT_CHANNELS=#incidents

# Notion
NOTION_TOKEN=CHANGE_ME
NOTION_DATABASE_ID=CHANGE_ME

# Optional
DEFAULT_REPO_ID=
